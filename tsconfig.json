{
  "extends": "@tsconfig/node12/tsconfig.json",
  "compilerOptions": {
    "outDir": ".homeybuild/",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "app.ts",
    "lib/**/*.ts",
    "drivers/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".homeybuild"
  ]
}
